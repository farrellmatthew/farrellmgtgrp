<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ExistX Brand Guidelines — LLM Reference System</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --blue:       #185FA5;
  --blue-mid:   #2172BE;
  --blue-deep:  #0C447C;
  --blue-light: #E6F1FB;
  --blue-b:     #B5D4F4;
  --navy:       #08152A;
  --obsidian:   #0B1E38;
  --slate:      #1E2D42;
  --storm:      #2A3F5A;
  --signal:     #00C2FF;
  --sky:        #4FA3D8;
  --vrf:        #1DB584;
  --vrf-d:      #0E8A63;
  --vrf-l:      #E8F5EE;
  --surface:    #F4F6F9;
  --border:     #E2E8F0;
  --border-m:   #CBD5E1;
  --text1:      #08152A;
  --text2:      #4A5568;
  --muted:      #94A3B8;
  --mono: 'IBM Plex Mono', 'Liberation Mono', monospace;
  --sans: 'IBM Plex Sans', 'Liberation Sans', sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: var(--sans);
  font-size: 13px;
  line-height: 1.6;
  color: var(--text1);
  background: var(--surface);
}

/* ── NAV ── */
.nav {
  position: sticky;
  top: 0;
  background: var(--navy);
  border-bottom: 2px solid var(--blue);
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 0 32px;
  height: 48px;
  gap: 0;
}

.nav-brand {
  font-family: var(--mono);
  font-size: 13pt;
  font-weight: 500;
  color: #fff;
  margin-right: 32px;
  white-space: nowrap;
}

.nav-brand span {
  color: var(--signal);
}

.nav-links {
  display: flex;
  gap: 2px;
  flex: 1;
  overflow-x: auto;
}

.nav-link {
  font-family: var(--mono);
  font-size: 6.5pt;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  padding: 0 12px;
  height: 48px;
  display: flex;
  align-items: center;
  text-decoration: none;
  white-space: nowrap;
  border-bottom: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s;
}

.nav-link:hover { color: #fff; border-bottom-color: var(--blue); }
.nav-link.active { color: var(--signal); border-bottom-color: var(--signal); }

/* ── LAYOUT ── */
.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 32px 80px;
}

/* ── HERO ── */
.hero {
  background: var(--navy);
  border-bottom: 1px solid var(--storm);
  padding: 56px 0 48px;
  margin-bottom: 48px;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '∃X.P(X)';
  position: absolute;
  right: 32px;
  top: 50%;
  transform: translateY(-50%);
  font-family: var(--mono);
  font-size: 80pt;
  font-weight: 300;
  color: rgba(255,255,255,0.04);
  pointer-events: none;
  line-height: 1;
}

.hero-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 32px;
}

.hero-ey {
  font-family: var(--mono);
  font-size: 6pt;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--signal);
  margin-bottom: 12px;
}

.hero-title {
  font-family: var(--mono);
  font-size: 32pt;
  font-weight: 300;
  color: #fff;
  line-height: 1.1;
  margin-bottom: 10px;
}

.hero-title strong {
  font-weight: 500;
  color: var(--signal);
}

.hero-sub {
  font-size: 12pt;
  color: rgba(255,255,255,0.55);
  margin-bottom: 28px;
  max-width: 600px;
}

.file-chips {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.chip {
  font-family: var(--mono);
  font-size: 7pt;
  padding: 4px 12px;
  border-radius: 2px;
  letter-spacing: 0.08em;
  font-weight: 500;
}

.chip-rules  { background: rgba(24,95,165,0.3); color: var(--signal); border: 0.5px solid rgba(0,194,255,0.3); }
.chip-persona{ background: rgba(29,181,132,0.2); color: var(--vrf); border: 0.5px solid rgba(29,181,132,0.3); }
.chip-voice  { background: rgba(79,163,216,0.2); color: var(--sky); border: 0.5px solid rgba(79,163,216,0.3); }

/* ── SECTION ── */
.section {
  margin-bottom: 52px;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}

.section-num {
  font-family: var(--mono);
  font-size: 22pt;
  font-weight: 300;
  color: var(--blue);
  opacity: 0.4;
  line-height: 1;
  min-width: 32px;
}

.section-title {
  font-family: var(--mono);
  font-size: 11pt;
  font-weight: 500;
  color: var(--text1);
  letter-spacing: 0.02em;
}

.section-file {
  margin-left: auto;
  font-family: var(--mono);
  font-size: 6pt;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 2px;
}

/* ── COLOR SWATCHES ── */
.swatch-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 8px;
  margin-bottom: 16px;
}

.swatch {
  border-radius: 4px;
  overflow: hidden;
  border: 0.5px solid var(--border);
}

.swatch-color {
  height: 52px;
}

.swatch-info {
  padding: 8px 10px;
  background: #fff;
}

.swatch-name {
  font-family: var(--mono);
  font-size: 7pt;
  font-weight: 500;
  color: var(--text1);
  margin-bottom: 2px;
}

.swatch-hex {
  font-family: var(--mono);
  font-size: 6.5pt;
  color: var(--muted);
}

.swatch-use {
  font-size: 6.5pt;
  color: var(--text2);
  line-height: 1.4;
  margin-top: 3px;
}

.swatch-restricted {
  border-top: 2px solid var(--signal);
}

/* ── TABLE ── */
.tbl {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 16px;
}

.tbl th {
  font-family: var(--mono);
  font-size: 6.5pt;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--blue);
  padding: 8px 12px;
  text-align: left;
  background: var(--blue-light);
  border-bottom: 1px solid var(--blue-b);
}

.tbl td {
  padding: 9px 12px;
  border-bottom: 0.5px solid var(--border);
  font-size: 12px;
  vertical-align: top;
  line-height: 1.5;
}

.tbl tr:last-child td { border-bottom: none; }
.tbl tr:nth-child(even) td { background: #fafbfd; }

.tbl td code {
  font-family: var(--mono);
  font-size: 10px;
  background: var(--blue-light);
  color: var(--blue-deep);
  padding: 1px 5px;
  border-radius: 2px;
}

/* ── RULE BOX ── */
.rule-box {
  border-left: 3px solid var(--blue);
  background: var(--blue-light);
  padding: 12px 16px;
  border-radius: 0 4px 4px 0;
  margin-bottom: 12px;
}

.rule-box.signal {
  border-left-color: var(--signal);
  background: rgba(0,194,255,0.06);
}

.rule-box.vrf {
  border-left-color: var(--vrf);
  background: var(--vrf-l);
}

.rule-box.warn {
  border-left-color: #E24B4A;
  background: #FCEBEB;
}

.rule-lbl {
  font-family: var(--mono);
  font-size: 6pt;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 4px;
}

.rule-box.signal .rule-lbl { color: var(--signal); }
.rule-box.vrf .rule-lbl    { color: var(--vrf-d); }
.rule-box.warn .rule-lbl   { color: #A32D2D; }

.rule-text {
  font-size: 12px;
  color: var(--text1);
  line-height: 1.55;
}

/* ── FONT SHOWCASE ── */
.font-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12px;
  margin-bottom: 16px;
}

.font-card {
  background: #fff;
  border: 0.5px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
}

.font-card-top {
  background: var(--navy);
  padding: 16px;
  min-height: 80px;
  display: flex;
  align-items: flex-end;
}

.font-sample-mono {
  font-family: var(--mono);
  font-size: 22pt;
  font-weight: 300;
  color: #fff;
  line-height: 1;
}

.font-sample-sans {
  font-family: var(--sans);
  font-size: 18pt;
  font-weight: 400;
  color: rgba(255,255,255,0.9);
  line-height: 1.2;
}

.font-sample-serif {
  font-family: 'Times New Roman', serif;
  font-size: 16pt;
  color: rgba(255,255,255,0.85);
  line-height: 1.4;
}

.font-card-body {
  padding: 12px 14px;
}

.font-name {
  font-family: var(--mono);
  font-size: 8pt;
  font-weight: 500;
  color: var(--text1);
  margin-bottom: 2px;
}

.font-fallback {
  font-family: var(--mono);
  font-size: 6.5pt;
  color: var(--muted);
  margin-bottom: 6px;
}

.font-use {
  font-size: 11px;
  color: var(--text2);
  line-height: 1.5;
}

/* ── VOICE EXAMPLES ── */
.voice-compare {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 12px;
}

.vc-good {
  background: var(--vrf-l);
  border: 0.5px solid rgba(29,181,132,0.35);
  border-left: 3px solid var(--vrf);
  border-radius: 0 4px 4px 0;
  padding: 12px 14px;
}

.vc-bad {
  background: #FCEBEB;
  border: 0.5px solid rgba(162,45,45,0.2);
  border-left: 3px solid #E24B4A;
  border-radius: 0 4px 4px 0;
  padding: 12px 14px;
}

.vc-lbl {
  font-family: var(--mono);
  font-size: 5.8pt;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.vc-good .vc-lbl { color: var(--vrf-d); }
.vc-bad  .vc-lbl { color: #A32D2D; }

.vc-text {
  font-size: 11.5px;
  line-height: 1.55;
  color: var(--text1);
}

/* ── VOCAB TABLE ── */
.vocab-row {
  display: flex;
  gap: 0;
  border-bottom: 0.5px solid var(--border);
  padding: 8px 0;
  align-items: baseline;
}

.vocab-avoid {
  font-family: var(--mono);
  font-size: 10px;
  color: #A32D2D;
  text-decoration: line-through;
  width: 200px;
  flex-shrink: 0;
  padding-right: 16px;
}

.vocab-use {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--vrf-d);
  width: 200px;
  flex-shrink: 0;
  padding-right: 16px;
}

.vocab-reason {
  font-size: 11px;
  color: var(--text2);
  flex: 1;
}

/* ── PERSONA CARDS ── */
.persona-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 16px;
}

.persona-card {
  background: #fff;
  border: 0.5px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
}

.persona-card-hdr {
  background: var(--navy);
  padding: 10px 14px;
  border-bottom: 2px solid var(--blue);
}

.persona-card-title {
  font-family: var(--mono);
  font-size: 8pt;
  font-weight: 500;
  color: #fff;
  letter-spacing: 0.06em;
}

.persona-card-body {
  padding: 12px 14px;
}

.persona-item {
  display: flex;
  gap: 8px;
  padding: 4px 0;
  align-items: flex-start;
  font-size: 11.5px;
  color: var(--text2);
  line-height: 1.5;
}

.persona-dot {
  width: 5px;
  height: 5px;
  background: var(--blue);
  border-radius: 50%;
  margin-top: 6px;
  flex-shrink: 0;
}

/* ── ANTI-PERSONA ── */
.anti-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.anti-item {
  background: #FCEBEB;
  border: 0.5px solid rgba(162,45,45,0.2);
  border-left: 2px solid #E24B4A;
  border-radius: 0 3px 3px 0;
  padding: 10px 12px;
}

.anti-label {
  font-family: var(--mono);
  font-size: 7.5pt;
  font-weight: 500;
  color: #A32D2D;
  margin-bottom: 3px;
}

.anti-reason {
  font-size: 11px;
  color: var(--text2);
  line-height: 1.45;
}

/* ── GALOIS FRAMING ── */
.framing-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 16px;
}

.framing-good, .framing-bad {
  border-radius: 3px;
  padding: 10px 14px;
}

.framing-good { background: var(--vrf-l); border: 0.5px solid rgba(29,181,132,0.3); }
.framing-bad  { background: #FCEBEB; border: 0.5px solid rgba(162,45,45,0.2); }

.framing-lbl {
  font-family: var(--mono);
  font-size: 6pt;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.framing-good .framing-lbl { color: var(--vrf-d); }
.framing-bad  .framing-lbl { color: #A32D2D; }

.framing-item {
  font-family: var(--mono);
  font-size: 8pt;
  line-height: 1.8;
  color: var(--text1);
}

/* ── TAGLINE TABLE ── */
.tagline-row {
  background: #fff;
  border: 0.5px solid var(--border);
  border-radius: 4px;
  padding: 14px 16px;
  margin-bottom: 8px;
  display: grid;
  grid-template-columns: 200px 1fr 1fr;
  gap: 16px;
  align-items: start;
}

.tagline-mark {
  font-family: var(--mono);
  font-size: 10pt;
  font-weight: 500;
  color: var(--blue-deep);
}

.tagline-use {
  font-size: 11.5px;
  color: var(--text2);
  line-height: 1.5;
}

.tagline-never {
  font-size: 11px;
  color: #A32D2D;
  line-height: 1.5;
}

.tagline-lbl {
  font-family: var(--mono);
  font-size: 6pt;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 3px;
}

/* ── PIPELINE NODES ── */
.pipeline-demo {
  display: flex;
  flex-direction: column;
  gap: 4px;
  background: var(--obsidian);
  border-radius: 4px;
  padding: 14px;
  margin-bottom: 12px;
}

.pd-node {
  border-radius: 3px;
  padding: 8px 10px;
}

.pd-sig { background: var(--navy); border: 0.5px solid var(--blue); border-left: 3px solid var(--signal); }
.pd-mid { background: var(--slate); border: 0.5px solid var(--storm); border-left: 3px solid var(--blue); }
.pd-sky { background: var(--obsidian); border: 0.5pt solid var(--storm); border-left: 3px solid var(--sky); }

.pd-title { font-family: var(--mono); font-size: 8pt; font-weight: 500; color: #fff; }
.pd-sub   { font-family: var(--mono); font-size: 6pt; color: rgba(255,255,255,0.42); margin-top: 1px; }
.pd-title .cs { color: var(--signal); }
.pd-title .ck { color: var(--sky); }

.pd-arrow { text-align: center; color: var(--blue); font-size: 9pt; opacity: 0.5; padding: 2px 0; }

/* ── TRL BAR DEMO ── */
.trl-demo {
  background: var(--navy);
  border-radius: 4px;
  padding: 14px 16px;
  margin-bottom: 12px;
}

.trl-lbl {
  font-family: var(--mono);
  font-size: 6pt;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  margin-bottom: 8px;
}

.trl-cells {
  display: flex;
  gap: 3px;
}

.trl-cell {
  flex: 1;
  height: 28px;
  border-radius: 2px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--mono);
  font-size: 8pt;
  font-weight: 500;
}

.trl-active { background: var(--blue); color: #fff; }
.trl-dim    { background: #E2E8F0; color: var(--muted); }

.trl-sublabel {
  font-family: var(--mono);
  font-size: 5.5pt;
  color: var(--sky);
  text-align: center;
  margin-top: 5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* ── SECTION LABEL DEMO ── */
.sec-demo {
  font-family: var(--mono);
  font-size: 6pt;
  font-weight: bold;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  padding: 5px 12px;
  border-radius: 0 3px 3px 0;
  margin-bottom: 8px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.sec-demo::before {
  content: '';
  display: block;
  width: 3px;
  height: 10px;
  background: currentColor;
  opacity: 0.6;
}

.sec-light { color: var(--blue); background: var(--blue-light); border-bottom: 0.5px solid var(--blue-b); }
.sec-dark  { color: var(--signal); background: var(--navy); border-bottom: 0.5px solid var(--storm); }
.sec-mid   { color: var(--sky); background: var(--obsidian); border-bottom: 0.5px solid var(--storm); }

/* ── LAYOUT DIAGRAM ── */
.layout-diagram {
  border: 0.5px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 12px;
}

.ld-header { background: var(--navy); height: 40px; display: flex; align-items: center; padding: 0 12px; }
.ld-header-txt { font-family: var(--mono); font-size: 7pt; color: rgba(255,255,255,0.5); }
.ld-body { display: flex; height: 120px; }
.ld-left  { width: 25%; background: var(--surface); border-right: 0.5px solid var(--border); display: flex; align-items: center; justify-content: center; }
.ld-center{ flex: 1; background: #fff; border-right: 0.5px solid var(--border); display: flex; align-items: center; justify-content: center; }
.ld-right { width: 22%; background: var(--surface); display: flex; align-items: center; justify-content: center; }
.ld-label { font-family: var(--mono); font-size: 6pt; color: var(--muted); text-align: center; line-height: 1.5; }
.ld-footer { background: var(--surface); height: 22px; border-top: 0.5px solid var(--border); display: flex; align-items: center; padding: 0 12px; }
.ld-footer-txt { font-family: var(--mono); font-size: 6pt; color: var(--muted); }

/* ── CONFLICT TABLE ── */
.conflict-tbl {
  background: var(--navy);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 16px;
}

.ct-row {
  display: grid;
  grid-template-columns: 120px 1fr 1fr;
  gap: 0;
  border-bottom: 0.5px solid var(--storm);
}

.ct-row:last-child { border-bottom: none; }

.ct-cell {
  padding: 10px 14px;
  font-family: var(--mono);
  font-size: 8pt;
  line-height: 1.5;
}

.ct-type { background: var(--slate); color: var(--sky); border-right: 0.5px solid var(--storm); }
.ct-winner { color: var(--signal); border-right: 0.5px solid var(--storm); }
.ct-example { color: rgba(255,255,255,0.45); font-size: 7pt; }

.ct-head .ct-cell { background: var(--obsidian); color: var(--muted); font-size: 6.5pt; letter-spacing: 0.1em; text-transform: uppercase; }
.ct-head .ct-type { background: var(--storm); }

/* ── QUICK REFERENCE ── */
.qr-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.qr-card {
  background: #fff;
  border: 0.5px solid var(--border);
  border-top: 3px solid var(--blue);
  border-radius: 0 0 4px 4px;
  padding: 14px;
}

.qr-card.rules  { border-top-color: var(--signal); }
.qr-card.persona{ border-top-color: var(--vrf); }
.qr-card.voice  { border-top-color: var(--sky); }

.qr-title {
  font-family: var(--mono);
  font-size: 7.5pt;
  font-weight: 500;
  margin-bottom: 10px;
  padding-bottom: 6px;
  border-bottom: 0.5px solid var(--border);
}

.qr-card.rules  .qr-title { color: var(--signal); }
.qr-card.persona .qr-title { color: var(--vrf-d); }
.qr-card.voice  .qr-title { color: var(--sky); }

.qr-item {
  font-family: var(--mono);
  font-size: 7pt;
  color: var(--text2);
  padding: 3px 0;
  border-bottom: 0.5px solid var(--border);
  line-height: 1.45;
}

.qr-item:last-child { border-bottom: none; }

/* ── OVERRIDE NOTE ── */
.override-banner {
  background: var(--obsidian);
